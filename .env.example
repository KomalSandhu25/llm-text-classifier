# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=llm-text-classifier

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_NAME=distilbert-base-uncased
NUM_LABELS=4

# ── Training hyperparameters ─────────────────────────────────────────────────
MAX_SEQ_LENGTH=128
BATCH_SIZE=32
NUM_EPOCHS=5
LEARNING_RATE=2e-5
WEIGHT_DECAY=0.01
WARMUP_RATIO=0.1
FP16=true

# ── Data ─────────────────────────────────────────────────────────────────────
DATASET_NAME=ag_news
DATA_DIR=./data
TEST_SIZE=0.1
VAL_SIZE=0.1

# ── Serving ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MODEL_PATH=./models/best_model.onnx
